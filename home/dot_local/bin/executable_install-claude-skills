#!/usr/bin/env bash
# Install Claude Code skills into ~/.claude/skills/ from the manifest at
# ~/.claude/skills.txt (see that file for the format).
#
# Idempotent: a skill folder that already exists is left untouched. To refresh
# one, delete its folder (or the whole clone cache) and re-run. Pass --force to
# overwrite every skill folder from a fresh clone.
#
# Public repos clone anonymously; private ones (e.g. my own claude-skills) need
# `gh` installed and authenticated (`gh auth login`) — the installer falls back
# to `gh repo clone` when an anonymous HTTPS clone fails.
set -euo pipefail

CLAUDE_DIR="${HOME}/.claude"
SKILLS_DIR="${CLAUDE_DIR}/skills"
MANIFEST="${CLAUDE_DIR}/skills.txt"
CACHE_DIR="${HOME}/.cache/claude-skills"

# Skill folders to never install (upstream placeholders, not real skills).
SKIP_SKILLS=" template "

FORCE=0
[ "${1:-}" = "--force" ] && FORCE=1

command -v git >/dev/null 2>&1 || { echo "error: git is required" >&2; exit 1; }
[ -f "$MANIFEST" ] || { echo "error: manifest not found at $MANIFEST" >&2; exit 1; }

mkdir -p "$SKILLS_DIR" "$CACHE_DIR"

install_skill_dir() {  # <source-skill-dir> <target-name>
  local src="$1" name="$2" dest
  case "$SKIP_SKILLS" in *" $name "*) return 0 ;; esac
  dest="$SKILLS_DIR/$name"
  if [ -e "$dest" ] && [ "$FORCE" -ne 1 ]; then
    return 0
  fi
  rm -rf "$dest"
  cp -R "$src" "$dest"
  rm -rf "$dest/.git"
  echo "  + $name"
}

process_repo() {  # <owner/repo> [root-name] [allowlist]
  local repo="$1" root_name="${2:-}" allow="${3:-}"
  local owner reponame clone f skill_dir name installed want
  owner="${repo%%/*}"
  reponame="${repo##*/}"
  clone="$CACHE_DIR/${owner}_${reponame}"

  echo "==> $repo${allow:+  (only: $allow)}"
  if [ -d "$clone/.git" ]; then
    git -C "$clone" fetch --depth 1 --quiet origin 2>/dev/null || true
    git -C "$clone" reset --hard --quiet "@{upstream}" 2>/dev/null || true
  else
    rm -rf "$clone"
    # Public repos clone anonymously over HTTPS (works on any machine, no auth).
    # A private repo (e.g. my own claude-skills) fails that, so fall back to gh,
    # which authenticates with its token. Needs `gh auth login` on the machine.
    if ! git clone --depth 1 --quiet "https://github.com/${repo}" "$clone" 2>/dev/null; then
      if command -v gh >/dev/null 2>&1; then
        gh repo clone "$repo" "$clone" -- --depth 1 --quiet \
          || { echo "  ! could not clone $repo (check access / gh auth)" >&2; return 0; }
      else
        echo "  ! could not clone $repo (private?) and gh is not installed" >&2
        return 0
      fi
    fi
  fi

  # Each SKILL.md marks a skill. Root-level SKILL.md => whole repo is the skill.
  # With an allowlist, only the named skill folders are installed.
  # (find|while runs in a subshell, so record installed names to a temp file.)
  installed="$(mktemp)"
  find "$clone" -name SKILL.md -not -path '*/.git/*' -print | while IFS= read -r f; do
    skill_dir="$(dirname "$f")"
    if [ "$skill_dir" -ef "$clone" ]; then
      name="${root_name:-${owner}_${reponame}}"
    else
      name="$(basename "$skill_dir")"
    fi
    if [ -n "$allow" ]; then
      case " $allow " in *" $name "*) ;; *) continue ;; esac
    fi
    install_skill_dir "$skill_dir" "$name"
    echo "$name" >> "$installed"
  done

  # Flag allowlisted skills missing from the clone (typo or renamed upstream),
  # so a silently-skipped skill is never mistaken for an installed one.
  if [ -n "$allow" ]; then
    for want in $allow; do
      grep -qxF "$want" "$installed" 2>/dev/null || echo "  ! '$want' not found in $repo" >&2
    done
  fi
  rm -f "$installed"
}

# `find | while` runs in a subshell, so counters there are lost; recompute after.
before=$(find "$SKILLS_DIR" -maxdepth 1 -mindepth 1 -type d | wc -l | tr -d ' ')

while IFS= read -r line; do
  line="${line%%#*}"                     # strip comments
  line="$(echo "$line" | xargs)"         # trim whitespace
  [ -z "$line" ] && continue
  if [[ "$line" == *:* ]]; then          # owner/repo : skill1 skill2 ...
    repo="$(echo "${line%%:*}" | xargs)"
    allow="$(echo "${line#*:}" | xargs)"
    process_repo "$repo" "" "$allow"
  else                                   # owner/repo [root-name]
    # shellcheck disable=SC2086
    process_repo $line
  fi
done < "$MANIFEST"

after=$(find "$SKILLS_DIR" -maxdepth 1 -mindepth 1 -type d | wc -l | tr -d ' ')
echo
echo "Done. ~/.claude/skills now has $after skill folders (was $before)."
echo "Re-run with --force to overwrite existing folders from fresh clones."
